; ここでは以下の前提で例示しています:
;   - 対向 PBX サーバのアドレス: tel.example-tailnet.ts.net
;   - trunk 名 (ユーザ名): SIP-TRUNK-EXAMPLE
;   - パスワード: SIP-TRUNK-EXAMPLE-PASSWORD

[example-tel](external-trunk-registration)
server_uri = sip:tel.example-tailnet.ts.net
client_uri = sip:SIP-TRUNK-EXAMPLE@tel.example-tailnet.ts.net
contact_user = SIP-TRUNK-EXAMPLE
outbound_auth = example-tel

[example-tel](external-trunk-auth)
username = SIP-TRUNK-EXAMPLE
password = WG5nQUN3dFJEcTQ9

[example-tel](external-trunk-aor)
contact = sip:SIP-TRUNK-EXAMPLE@tel.example-tailnet.ts.net

[example-tel](external-trunk-endpoint)
aors = example-tel
auth = example-tel
outbound_auth = example-tel
from_user = SIP-TRUNK-EXAMPLE
from_domain = tel.example-tailnet.ts.net
contact_user = SIP-TRUNK-EXAMPLE

[example-tel](external-trunk-identify)
endpoint = example-tel
match = tel.example-tailnet.ts.net
